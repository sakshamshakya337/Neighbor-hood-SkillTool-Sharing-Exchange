    "lucide-react": "^1.23.0",
    "mongoose": "^9.7.4",
    "nodemailer": "^9.0.3",
    "postcss": "^8.5.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
